{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Plugin",
  "type": "object",
  "required": ["name", "description", "author", "repository", "category", "source", "commit_date", "source_hash"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)+$",
      "description": "Kebab-case skill name, at least 2 words"
    },
    "description": {
      "type": "string",
      "pattern": "TRIGGER when:?",
      "minLength": 50,
      "description": "Short description followed by TRIGGER when or TRIGGER when: clause"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "architecture",
          "execution-control",
          "state-memory",
          "persistence",
          "networking",
          "tools",
          "RAG",
          "data-learning",
          "security",
          "monitoring-evaluation",
          "operations-deployment"
        ]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Skill categories (primary first)"
    },
    "source": {
      "type": "string",
      "pattern": "^(internal|external(\\s+\\(?https?://.+\\)?)?|engram)$",
      "description": "internal, external optionally followed by the repo URL, or engram for promoted personal knowledge"
    },
    "commit_date": {
      "type": "string",
      "pattern": "^\\d{2}-\\d{2}-\\d{4}$",
      "description": "Commit date"
    },
    "source_hash": {
      "type": ["string", "null"],
      "description": "Short git commit hash from source repo, or null if unavailable"
    }
  }
}
